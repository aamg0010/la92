# =====================================================
# Clinident - Docker Compose environment (EXAMPLE)
# =====================================================
# Copia este archivo a `.env` (nunca lo commitees) y
# reemplazá los valores PLACEHOLDER por secretos reales.
#
# IMPORTANTE: JWT_SECRET debe coincidir EXACTAMENTE con
# el valor de VITE_JWT_SECRET en D:/la92/.env.production
# — de lo contrario el frontend no podrá autenticarse
# contra este PostgREST.
# =====================================================

POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
API_ROLE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
JWT_SECRET=CHANGE_ME_MUST_MATCH_VITE_JWT_SECRET
